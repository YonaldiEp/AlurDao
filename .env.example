# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
# Hanya server; jangan pernah memakai prefix NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth untuk Supabase lokal (jangan prefix NEXT_PUBLIC pada secret)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# Pilih: demo | mistral | gemini | groq | ollama
AI_PROVIDER=demo

# Rahasia server untuk menandatangani cookie limit demo (buat minimal 32 karakter acak)
DEMO_COOKIE_SECRET=

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# Ollama lokal
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:4b

# Midtrans Snap (placeholder secara default untuk demo/presentasi)
MIDTRANS_ENABLE_REAL_CHECKOUT=false
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
PREMIUM_PRICE_IDR=49000
